{
  "name": "@jpabloe/wasapi-mcp-server",
  "version": "0.2.3",
  "description": "MCP server for Wasapi — manage contacts and send WhatsApp messages via Claude",
  "main": "dist/index.js",
  "bin": {
    "wasapi-mcp": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "rm -rf dist && npm run build && find dist -name .DS_Store -delete",
    "package:dxt": "node scripts/build-dxt.mjs"
  },
  "keywords": [],
  "author": {
    "name": "Juan Pablo",
    "email": "juanpablo@vinixcode.com",
    "url": "https://github.com/jpabloe"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpabloe/wasapi-mcp-server.git"
  },
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@wasapi/js-sdk": "^0.1.38",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "archiver": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
